{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && pnpm --filter @azdek/backend build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @azdek/backend start",
    "healthcheckPath": "/v1/doctor/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
