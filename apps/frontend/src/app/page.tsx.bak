                          onClick={(e) => { e.preventDefault(); useCartStore.getState().addItem({ slug: `product-${p.id}`, name: p.name, sub: p.sub, price: parseInt(p.price.replace(/\D/g, '')) }); toast.success('РўРѕРІР°СЂ РґРѕР±Р°РІР»РµРЅ РІ РєРѕСЂР·РёРЅСѓ!', { description: p.name }); }}
