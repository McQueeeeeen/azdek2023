# Backend
NODE_ENV=development
BACKEND_PORT=4000`nFRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgresql://postgres.<project_ref>:<DB_PASSWORD>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
REDIS_URL=redis://localhost:6379
LOG_LEVEL=log
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=product-media
PAYMENT_WEBHOOK_SECRET_MOCK_KZ=replace-with-webhook-secret`nQUEUE_WORKERS_ENABLED=false
JWT_ACCESS_SECRET=replace-with-strong-jwt-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_REFRESH_TTL=30d
AUTH_BOOTSTRAP_KEY=replace-with-bootstrap-key

# Frontend
